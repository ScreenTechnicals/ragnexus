{
  "name": "ragnexus",
  "version": "1.0.1",
  "description": "A deterministically safe RAG + Memory SDK built to run anywhere.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "chat": "vite-node examples/openai-ink.tsx"
  },
  "keywords": [
    "rag",
    "ai",
    "llm",
    "memory",
    "context",
    "vercel-ai-sdk",
    "openai",
    "guardrails",
    "crawler"
  ],
  "author": "RagNexus Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ScreenTechnicals/ragnexus.git"
  },
  "bugs": {
    "url": "https://github.com/ScreenTechnicals/ragnexus/issues"
  },
  "homepage": "https://github.com/ScreenTechnicals/ragnexus#readme",
  "type": "commonjs",
  "devDependencies": {
    "@crawlee/playwright": "^3.16.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "playwright": "^1.58.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@genkit-ai/googleai": "^1.28.0",
    "@google/genai": "^1.45.0",
    "cohere-ai": "^7.20.0",
    "dotenv": "^17.3.1",
    "genkit": "^1.30.1",
    "gpt-tokenizer": "^3.4.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "openai": "^6.27.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.4",
    "vite-node": "^6.0.0"
  }
